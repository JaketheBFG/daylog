# RevenueCat iOS public API key
# Get this from app.revenuecat.com → Project → API Keys
VITE_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RevenueCat secret key (server-side only, never expose to client)
# Get this from app.revenuecat.com → Project → API Keys → Secret keys
REVENUECAT_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key (server-side only)
# Get this from supabase.com → Project Settings → API → service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxx
